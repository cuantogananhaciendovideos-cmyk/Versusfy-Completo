rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny: No one can read or write unless explicitly allowed below.
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection Test Document - used by the app to verify Firebase setup.
    match /test/connection {
      allow read: if true;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      // Hardened ID check: string, max 128 chars, safe chars only.
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Marketing Phrases
    match /marketing_phrases/{phraseId} {
      allow read: if true;
      allow write: if true; 
    }

    // Visitor tracking
    match /visitors/{visitorId} {
      allow read, write: if true; 
    }

    // AI Comparisons
    match /comparisons/{comparisonId} {
      allow read, create, update: if true; 
    }

    // Metadata & Global Config
    match /meta/{metaId} {
      allow read, write: if true; 
    }

    match /trending_comparisons/{comparisonId} {
      allow read, write: if true; 
    }

    match /trending_votes/{comparisonId} {
      allow read, write: if true;
    }

    // Shopping & Alerts
    match /shopping_desires/{desireId} {
      allow read, write: if true;
    }

    match /personal_buyer_alerts/{alertId} {
      allow read, write: if true;
    }

    match /price_alerts/{alertId} {
      allow read, write: if true;
    }

    match /testimonials/{testimonialId} {
      allow read, write: if true;
    }

    match /coupons/{couponId} {
      allow read, write: if true;
    }
  }
}
