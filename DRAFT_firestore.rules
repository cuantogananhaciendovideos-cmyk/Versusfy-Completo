rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny: No one can read or write unless explicitly allowed below.
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection Test Document
    match /test/connection {
      allow read: if true;
    }

    // ===============================================================
    // Global Helpers
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isServerTime(field) {
      return incoming()[field] == request.time;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    // ===============================================================
    // Entity Validations
    // ===============================================================

    function isValidForumPost(data) {
      return data.keys().hasAll(['isAnonymous', 'content', 'likes', 'hearts', 'rating', 'createdAt']) 
        && data.keys().size() <= 11 // Adjusted for optional fields
        && data.isAnonymous is bool
        && isValidString(data.content, 2000)
        && data.likes is int && data.likes == 0 // Only 0 on create
        && data.hearts is int && data.hearts == 0
        && data.rating is int && data.rating >= 1 && data.rating <= 5
        && data.createdAt == request.time
        && (!data.isAnonymous ? (data.firstName is string && data.lastName is string) : true)
        && (data.has('photoUrl') ? isValidString(data.photoUrl, 500) : true)
        && (data.has('sharedImage') ? isValidString(data.sharedImage, 500) : true)
        && (data.has('heroTicketId') ? isValidString(data.heroTicketId, 100) : true);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /forum_posts/{postId} {
      allow list: if true; // Everyone can see the tactical feed
      allow get: if isValidId(postId);

      allow create: if isValidId(postId) 
        && isValidForumPost(incoming());

      allow update: if isValidId(postId) && (
        // Action: Engagement (Likes/Hearts)
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['likes']) 
          && incoming().likes == existing().likes + 1
        ) ||
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['hearts']) 
          && incoming().hearts == existing().hearts + 1
        )
      );

      allow delete: if false; // Only sysadmins can delete tactical records
    }

    // Hardened existing rules
    match /marketing_phrases/{phraseId} {
      allow read: if true;
      allow write: if false; // Locked from client side
    }

    match /visitors/{visitorId} {
      allow read, write: if isValidId(visitorId); 
    }

    match /comparisons/{comparisonId} {
      allow read: if true;
      allow create: if isValidId(comparisonId) && incoming().keys().hasAll(['text']);
      allow update: if false;
    }

    match /meta/{metaId} {
      allow read: if true;
      allow write: if false;
    }

    match /trending_comparisons/{comparisonId} {
      allow read: if true;
      allow write: if false;
    }

    match /trending_votes/{comparisonId} {
      allow read: if true;
      allow write: if isValidId(comparisonId);
    }

    match /shopping_desires/{desireId} {
      allow read, write: if true;
    }

    match /personal_buyer_alerts/{alertId} {
      allow read, write: if true;
    }

    match /price_alerts/{alertId} {
      allow read, write: if true;
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if false;
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if false;
    }

    match /pathfinder_votes/{voteId} {
      allow read: if true;
      allow create: if true;
    }

    match /stats/{statId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
